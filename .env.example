# PostgreSQL Configuration
POSTGRES_DB=portfolio_db
POSTGRES_USER=portfolio_user
POSTGRES_PASSWORD=strong_password_here_123
POSTGRES_HOST=postgres  # Или db, в зависимости от имени сервиса в docker-compose
POSTGRES_PORT=5432

# Application Configuration
ENVIRONMENT=development
DEBUG=True
API_PORT=8001

# CORS Origins (comma-separated for FastAPI middleware)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,https://yourdomain.com

# Security
SECRET_KEY=your-super-secret-key-change-this-in-production-12345
JWT_SECRET_KEY=your-super-secret-key-change-this-in-production-12345

# Redis cache
REDIS_URL=redis://redis:6379/0
CACHE_ENABLED=true
CACHE_TTL_SECONDS=300

# PgAdmin Configuration
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=admin123
PGADMIN_PORT=5050
